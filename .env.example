# ====================================
# Hermes AI OS - Environment Variables Template
# Copy this to .env and configure your values
# ====================================

# PRIORITY 1 - MUST CONFIGURE THESE

# Application
ENVIRONMENT=development
APP_NAME=Hermes AI OS
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=change-this-to-random-secret-key

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/hermes_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=hermes_ai
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# LLM Provider (Choose one or multiple)
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Embeddings
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector Database
VECTOR_DB=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-this-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Feature Flags
ENABLE_VOICE=true
ENABLE_RAG=true
ENABLE_MEMORY=true
ENABLE_STREAMING=true

# See .env.example for all configuration options
