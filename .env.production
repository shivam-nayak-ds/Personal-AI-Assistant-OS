# ====================================
# Production Environment Configuration
# ====================================

ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=WARNING
LOG_FORMAT=json

# Application
APP_NAME=Hermes AI OS
APP_VERSION=1.0.0
SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-SUPER-SECRET-KEY
API_KEY=CHANGE-THIS-API-KEY-IN-PRODUCTION

# Database - Production (Use managed service)
DATABASE_URL=postgresql://user:password@prod-db-host:5432/hermes_ai_prod
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis - Production (Use managed service)
REDIS_URL=redis://prod-redis-host:6379/0
REDIS_PASSWORD=YOUR-REDIS-PASSWORD

# Vector DB - Production
VECTOR_DB=pinecone
PINECONE_API_KEY=YOUR-PINECONE-KEY
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=hermes-prod

# LLM - Production settings
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=YOUR-OPENAI-KEY
OPENAI_MODEL=gpt-4
MAX_AGENT_ITERATIONS=10
MAX_CONTEXT_LENGTH=16000

# Security - Strict
COOKIE_SECURE=true
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=strict
JWT_SECRET_KEY=CHANGE-THIS-JWT-SECRET-IN-PRODUCTION
ENCRYPTION_KEY=CHANGE-THIS-ENCRYPTION-KEY
PASSWORD_MIN_LENGTH=12
BCRYPT_ROUNDS=12

# CORS - Restricted
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOW_CREDENTIALS=true

# Rate Limiting - Strict
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500

# Celery - Production
CELERY_BROKER_URL=redis://prod-redis:6379/1
CELERY_RESULT_BACKEND=redis://prod-redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TRACK_STARTED=true

# Monitoring - Enabled
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENABLE_TELEMETRY=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector:4317

# Object Storage - AWS S3
AWS_ACCESS_KEY_ID=YOUR-AWS-KEY
AWS_SECRET_ACCESS_KEY=YOUR-AWS-SECRET
AWS_BUCKET=hermes-prod-uploads
AWS_REGION=us-east-1

# Email - Production SMTP
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=YOUR-SENDGRID-API-KEY
EMAIL_FROM=noreply@yourdomain.com
EMAIL_VERIFICATION=true

# Feature Flags
ENABLE_VOICE=true
ENABLE_IMAGE=true
ENABLE_DOCUMENT_CHAT=true
ENABLE_WEB_SEARCH=true
ENABLE_CODE_INTERPRETER=false

# Cache - Longer TTL
CACHE_TTL=3600
CACHE_ENABLED=true

# Session - Production settings
SESSION_TIMEOUT=30
MAX_CONCURRENT_USERS=1000
WEBSOCKET_MAX_CONNECTIONS=5000

# AI Limits
MAX_CHAT_HISTORY=20
MAX_UPLOAD_FILES=10
MAX_RAG_DOCUMENTS=5
MAX_TOKENS_PER_REQUEST=4000

# Background Jobs
ENABLE_BACKGROUND_JOBS=true
SCHEDULER_TIMEZONE=UTC

# Integrations
GOOGLE_CLIENT_ID=YOUR-GOOGLE-CLIENT-ID
GOOGLE_CLIENT_SECRET=YOUR-GOOGLE-SECRET
NOTION_API_KEY=YOUR-NOTION-KEY
GITHUB_TOKEN=YOUR-GITHUB-TOKEN
