# ====================================
# Hermes AI OS - Environment Variables
# ====================================

# ============================================
# PRIORITY 1 - MUST HAVE
# ============================================

# 1. Application Settings
ENVIRONMENT=development
APP_NAME=Hermes AI OS
APP_VERSION=1.0.0
DEBUG=True
API_VERSION=v1
SECRET_KEY=hermes-super-secret-key-change-in-production-2024

# Server Configuration
HOST=0.0.0.0
PORT=8000

# 2. Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/hermes_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=hermes_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 3. Multi-LLM Support
DEFAULT_LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Groq (Fast inference)
GROQ_API_KEY=

# OpenRouter (Multi-model gateway)
OPENROUTER_API_KEY=

# 4. Embeddings Configuration
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# 5. Vector Database Configuration
VECTOR_DB=qdrant

# Qdrant (Local/Cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=hermes-knowledge

# Pinecone (Cloud)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=hermes-knowledge

# 6. Agent Configuration
MAX_AGENT_ITERATIONS=10
MAX_CONTEXT_LENGTH=16000
ENABLE_MEMORY=true
ENABLE_RAG=true
ENABLE_STREAMING=true

# 7. Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 8. Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log
LOG_ROTATION=10MB
LOG_RETENTION_DAYS=30

# 9. Security Configuration
API_KEY=
ENCRYPTION_KEY=
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Security
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

# 10. Object Storage Configuration
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=us-east-1

# MinIO (Local S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=hermes-uploads
MINIO_SECURE=false

# 11. Monitoring & Observability
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
ENABLE_TELEMETRY=false

# 12. Feature Flags
ENABLE_VOICE=true
ENABLE_IMAGE=true
ENABLE_DOCUMENT_CHAT=true
ENABLE_WEB_SEARCH=true
ENABLE_CODE_INTERPRETER=true

# ============================================
# PRIORITY 2 - VERY USEFUL
# ============================================

# Cache Configuration
CACHE_TTL=3600
CACHE_ENABLED=true
CACHE_PREFIX=hermes:

# File Upload Configuration
MAX_FILE_SIZE_MB=20
MAX_UPLOAD_SIZE_MB=20
ALLOWED_FILE_TYPES=pdf,docx,txt,md,png,jpg,jpeg,csv,json
UPLOAD_DIR=./uploads

# Session Management
SESSION_TIMEOUT=30
MAX_CONCURRENT_USERS=100
SESSION_COOKIE_NAME=hermes_session

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOW_CREDENTIALS=true
ALLOW_METHODS=*
ALLOW_HEADERS=*

# WebSocket Configuration
WEBSOCKET_TIMEOUT=300
WEBSOCKET_MAX_CONNECTIONS=1000
WEBSOCKET_PING_INTERVAL=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_ENABLED=true

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TRACK_STARTED=true

# ============================================
# PRIORITY 3 - PRODUCTION
# ============================================

# Docker Environment
DOCKER_ENV=development

# Background Jobs & Scheduler
ENABLE_BACKGROUND_JOBS=true
SCHEDULER_TIMEZONE=UTC

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@hermesai.com
EMAIL_VERIFICATION=true
RESET_PASSWORD_EXPIRY=15

# AI Limits & Constraints
MAX_CHAT_HISTORY=20
MAX_UPLOAD_FILES=10
MAX_RAG_DOCUMENTS=5
MAX_TOKENS_PER_REQUEST=4000
MAX_MEMORY_ITEMS=100

# ============================================
# INTEGRATIONS (Optional)
# ============================================

# Google Calendar Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback

# Notion Integration
NOTION_API_KEY=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id

# GitHub Integration
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_USERNAME=

# Slack Integration (Optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ============================================
# VOICE & SPEECH
# ============================================

# Speech-to-Text
STT_PROVIDER=openai
WHISPER_MODEL=whisper-1

# Text-to-Speech
TTS_PROVIDER=openai
TTS_VOICE=shimmer
TTS_SPEED=1.0

# ============================================
# WEB SEARCH
# ============================================

SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERP_API_KEY=
BRAVE_API_KEY=

# ============================================
# ADVANCED FEATURES
# ============================================

# Code Interpreter
CODE_EXECUTION_TIMEOUT=30
ENABLE_CODE_SANDBOX=true

# Web Browser
ENABLE_WEB_BROWSER=false
PLAYWRIGHT_HEADLESS=true

# Multi-Modal
IMAGE_GENERATION_PROVIDER=dalle3
DALLE_MODEL=dall-e-3
STABLE_DIFFUSION_API_KEY=
